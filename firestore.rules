rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower() == "shashanknayal4@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 128 &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.keys().size() >= 5 &&
             data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             (!data.keys().hasAll(['userPhoto']) || (data.userPhoto is string && data.userPhoto.size() <= 500)) &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && 
                    (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']));
    }

    match /messages/{messageId} {
      allow get: if isValidId(messageId) && (isAdmin() || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid));
      allow list: if isAdmin() || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      
      allow create: if isValidId(messageId) && isSignedIn() && isValidMessage(incoming());
      
      allow delete: if isValidId(messageId) && isAdmin();
      allow update: if false;
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if true;
      allow create: if isValidId(reviewId) && isSignedIn() && isValidReview(incoming());
      allow delete: if isValidId(reviewId) && (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid));
      allow update: if isValidId(reviewId) && isSignedIn() && isOwner(resource.data.userId) && isValidReview(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'createdAt']);
    }
  }
}
